# Workbench API
PORT=4000
FRONTEND_ORIGIN=http://127.0.0.1:3000

# Required for current market data widgets.
# Must expose the OpenBB-compatible endpoints documented in README.md.
OPENBB_BASE_URL=http://127.0.0.1:6900

# Optional cache layer. If configured, route plans try QuestDB first and then
# fall back to OpenBB when cache data is unavailable.
# QUESTDB_URL=http://127.0.0.1:9000

# Optional Open Moniker route-plan resolver. When unset, the API uses local
# route-plan stubs for development. When set, unresolved monikers return data
# unavailable instead of falling back to a hardcoded provider.
# MONIKER_RESOLVER_URL=http://127.0.0.1:8050

# Optional chat model service.
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen3:32b

# Optional notebook kernel gateway. Start locally with:
# jupyter server --no-browser --port 8888 --ServerApp.token=''
# JUPYTER_GATEWAY_URL=http://127.0.0.1:8888
# JUPYTER_GATEWAY_TOKEN=secret

# Optional chat history persistence for the frontend.
# VITE_MEMORY_API_BASE_URL=http://127.0.0.1:8000
# VITE_MEMORY_USER_ID=workbench

# ---------------------------------------------------------------------------
# Horizontal scaling notes
# ---------------------------------------------------------------------------
#
# The data-router is stateless. Multiple instances can run concurrently against
# the same upstream services without coordination:
#
#   - No per-instance disk state. Route plans are resolved on every request
#     either from MONIKER_RESOLVER_URL or from in-process read-only stubs.
#   - No session or request affinity required. Any instance can handle any
#     request; a round-robin load balancer is sufficient.
#   - OPENBB_BASE_URL and QUESTDB_URL are shared upstreams. Point all instances
#     at the same service endpoints.
#   - Each instance can run on a different PORT when co-located on one host;
#     set PORT per instance or let the container runtime assign it.
#
# Health probes (use with Kubernetes or a load-balancer health checker):
#
#   GET /health  —  liveness: always 200 while the process is running.
#   GET /ready   —  readiness: 200 when downstream services are reachable,
#                   503 when OPENBB_BASE_URL is configured but unreachable.
#
# See deploy/docker-compose.example.yml for a worked multi-instance example.
