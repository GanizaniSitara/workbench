{
  "name": "workbench",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:data-router\" \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "vite",
    "dev:api": "tsx watch --clear-screen=false src/server/index.ts",
    "dev:data-router": "tsx watch --clear-screen=false src/server/data-router-server.ts",
    "dev:memory": "node scripts/local-memory-api.mjs",
    "build": "npm run build:web && npm run build:api",
    "build:web": "vite build",
    "build:api": "tsc -p tsconfig.server.json",
    "start": "concurrently \"npm run start:data-router\" \"npm run start:api\" \"npm run start:web\"",
    "start:web": "vite preview",
    "start:api": "node dist-api/server/index.js",
    "start:data-router": "node dist-api/server/data-router-server.js",
    "lint": "eslint src tests vite.config.ts playwright.config.ts",
    "lint:fix": "eslint src tests vite.config.ts playwright.config.ts --fix",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "playwright test --project=e2e-chromium",
    "test:api": "playwright test --project=api-contract",
    "test:visual": "playwright test --project=visual-desktop",
    "test:visual:update": "playwright test --project=visual-desktop --update-snapshots",
    "test:perf": "playwright test --project=performance",
    "test:regression": "node scripts/run-playwright-regression.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json",
    "codegen:engines": "node scripts/codegen-engines.mjs",
    "codegen:check": "npm run codegen:engines && git diff --exit-code src/lib/generated/engines.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tanstack/react-query": "^5.90.5",
    "@types/better-sqlite3": "^7.6.13",
    "ag-grid-community": "^34.3.1",
    "ag-grid-react": "^34.3.1",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "katex": "^0.16.45",
    "lightweight-charts": "^5.0.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-grid-layout": "^1.5.2",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-grid-layout": "^2.1.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "globals": "^16.4.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "typescript-eslint": "^8.46.2",
    "vite": "^7.1.12",
    "vitest": "^4.1.5"
  }
}
